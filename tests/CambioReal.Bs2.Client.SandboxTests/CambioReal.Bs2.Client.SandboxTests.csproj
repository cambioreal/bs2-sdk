<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CambioReal.Bs2.SandboxTests</RootNamespace>
    <AssemblyName>CambioReal.Bs2.Client.SandboxTests</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <!--
    Deliberadamente FORA de Bs2.slnx: `dotnet build`/`dotnet test Bs2.slnx` nunca toca este
    projeto, e portanto nenhum pipeline de CI genérico o executa por acidente (goal-loop §2.5:
    "testes de integração sandbox separados, marcados/opt-in, que nunca rodem por padrão em CI").
    Rodar explicitamente: ver README.md deste diretório.
  -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="Shouldly" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/CambioReal.Bs2.Client/CambioReal.Bs2.Client.csproj" />
  </ItemGroup>

</Project>
